do_install() {
	sed -i 's/Exec=proton-authenticator/Exec=env WEBKIT_DISABLE_DMABUF_RENDERER=1 proton-authenticator/' \
		"share/applications/Proton Authenticator.desktop"

	vcopy "*" /usr
}
