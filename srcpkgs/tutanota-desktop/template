pkgname=tutanota-desktop
version=340.260326.1
revision=2
archs="x86_64"
short_desc="Desktop client for Tutanota, the secure e-mail service"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="GPL-3.0-only"
homepage="https://tuta.com/"
changelog="https://github.com/tutao/tutanota/releases"
distfiles="https://github.com/tutao/tutanota/releases/download/tutanota-desktop-release-${version}/tutanota-desktop-${version}-unpacked-linux.tar.gz"
checksum=f467c39aa0f21a0f03e0dfb8c5c23b2cc9453562eb613143e326aa9cc6fdab08

do_install() {
	vmkdir usr/lib/tutanota-desktop
	vcopy * usr/lib/tutanota-desktop

	vbin ${FILESDIR}/tutanota-desktop.sh tutanota-desktop

	vinstall ${FILESDIR}/tutanota-desktop.desktop 644 \
		usr/share/applications
	vinstall resources/icons/icon/512.png 644 \
		usr/share/pixmaps tutanota.png
}
