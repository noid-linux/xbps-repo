# Template file for 'webapp-manager'
pkgname=webapp-manager
version=1.4.6
revision=1
archs="x86_64"
hostmakedepends="tar xz"
depends="python3-tldextract python3-xapp python3-Pillow
python3-BeautifulSoup4 python3-configobj python3-gobject
python3-setproctitle python3-tldextract xapp-symbolic-icons"
short_desc="Run websites as if they were apps"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/linuxmint/webapp-manager"
distfiles="https://github.com/linuxmint/webapp-manager/releases/download/master.mint22/packages.tar.gz"
checksum=09f677167c577b9add6ca797094d9594b7500228a62c9f097bc952533369b6c0
nostrip=yes

post_extract() {
	ar x ${pkgname}_${version}_all.deb
}

do_install() {
	tar xf data.tar.xz -C ${DESTDIR}
}