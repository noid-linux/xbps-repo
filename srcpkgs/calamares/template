configure_args="-DCMAKE_BUILD_TYPE=Release
 -DCMAKE_INSTALL_PREFIX=/usr
 -DCMAKE_INSTALL_LIBDIR=lib
 -DINSTALL_CONFIG:BOOL=ON
 -DINSTALL_POLKIT:BOOL=ON
 -DBUILD_APPDATA:BOOL=OFF
 -DBUILD_APPSTREAM:BOOL=OFF
 -DWITH_QT6:BOOL=ON
 -DSKIP_MODULES='services-systemd;oemid;initramfs;initramfscfg;tracking;interactiveterminal;dummyprocess;dummypython;dummycpp;dummypythonqt'"
hostmakedepends="git extra-cmake-modules pkg-config gettext ckbcomp
 kcoreaddons python3-QtPy libpwquality python3-yaml
 python3-jsonschema"
makedepends="python3-devel python3-jsonschema yaml-cpp-devel
 python3-yaml boost-devel qt6-base-devel python3-devel kpmcore-devel
 qt6-tools qt6-translations boost boost-python3 python3-QtPy
 qt6-svg-devel libpwquality qt6-webengine plasma-framework-devel
 qt6-webengine"
depends="kconfig kcoreaddons kiconthemes ki18n kio ksolid boost
 ckbcomp polkit-qt6 gtk-update-icon-cache plasma-framework
 squashfs-tools libpwquality icu rsync"
short_desc="Distribution-independent installer framework"
