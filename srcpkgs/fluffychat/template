# Template file for 'fluffychat'
pkgname=fluffychat
version=2.6.0
revision=1
archs="x86_64"
depends="xdg-user-dirs zenity jsoncpp"
short_desc="The cutest instant messenger in the [matrix]"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="AGPL-3.0-or-later"
homepage="https://fluffychat.im/"
distfiles="https://github.com/krille-chan/fluffychat/releases/download/v${version}/fluffychat-linux-x64.tar.gz"
checksum=e276a535b4c529b56cdb0811e8dd798016b7f95a901f93a9959ae958a3916a52
nostrip=yes

do_install() {
	vmkdir opt/${pkgname}	
	vcopy * opt/${pkgname}

	vmkdir usr/bin
	ln -sf /opt/${pkgname}/${pkgname} ${DESTDIR}/usr/bin/${pkgname}

    vinstall ${FILESDIR}/${pkgname}.desktop 644 usr/share/applications
    vinstall data/flutter_assets/assets/logo.svg 644 usr/share/pixmaps ${pkgname}.svg
}