# Template file for 'floorp'
pkgname=floorp
version=12.12.2
revision=1
archs="x86_64"
short_desc="Firefox fork seeking balance between versatility, privacy and openness"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="MPL-2.0"
homepage="https://floorp.app/"
changelog="https://blog.floorp.app/en/categories/release/"
distfiles="https://github.com/Floorp-Projects/Floorp/releases/download/v${version}/floorp-linux-x86_64.tar.xz"
checksum=c2157e29b3b9e41fb125ed0c607fb79da3f07b9dfcb37671b7bdf0bf6d818058
nostrip=yes

do_install() {
	vmkdir usr/lib/${pkgname}
	vcopy * usr/lib/${pkgname}/

	vbin ${FILESDIR}/${pkgname}.sh floorp

	vinstall ${FILESDIR}/${pkgname}.desktop 644 usr/share/applications/

	for i in 16 32 48 64 128; do
		vmkdir usr/share/icons/hicolor/${i}x${i}/apps
		ln -sf /usr/lib/${pkgname}/browser/chrome/icons/default/default${i}.png \
			${DESTDIR}/usr/share/icons/hicolor/${i}x${i}/apps/${pkgname}.png
	done

	vinstall ${FILESDIR}/policies.json 644 usr/lib/${pkgname}/distribution/
}
