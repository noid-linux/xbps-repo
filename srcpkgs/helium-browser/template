# Template file for 'helium-browser'
pkgname=helium-browser
version=0.13.4.1
revision=1
archs="x86_64"
depends="vulkan-loader"
short_desc="Private, fast, and honest web browser"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="GPL-3.0-only"
homepage="https://helium.computer/"
changelog="https://github.com/imputnet/helium/releases"
distfiles="https://github.com/imputnet/helium-linux/releases/download/${version}/helium-${version}-x86_64_linux.tar.xz"
checksum=aedfffc1c0271fb9f5a25fcf7cfdfb6b11e92142ab59749037a4a2b06b44ee1c
nostrip=yes

do_install() {
	vmkdir opt/${pkgname}
	vcopy "*" opt/${pkgname}

	vmkdir usr/bin
	ln -sf /opt/${pkgname}/helium-wrapper ${DESTDIR}/usr/bin/helium

	vinstall product_logo_256.png 644 \
		usr/share/icons/hicolor/256x256/apps helium.png

	vinstall helium.desktop 644 usr/share/applications

	rm -f ${DESTDIR}/opt/${pkgname}/product_logo_256.png
	rm -f ${DESTDIR}/opt/${pkgname}/libvulkan.so.1
	rm -f ${DESTDIR}/opt/${pkgname}/libEGL.so
	rm -f ${DESTDIR}/opt/${pkgname}/libGLESv2.so
}
