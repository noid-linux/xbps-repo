# Template file for 'libgsystemservice'
pkgname=libgsystemservice
version=0.3.0
revision=1
archs="x86_64"
build_style=meson
hostmakedepends="pkg-config gtk-doc"
makedepends="glib-devel polkit-devel"
short_desc="Common components needed for building services to be exposed on D-Bus"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="LGPL-2.1-or-later"
homepage="https://gitlab.gnome.org/pwithnall/libgsystemservice"
changelog="https://gitlab.gnome.org/pwithnall/libgsystemservice/-/raw/main/NEWS"
distfiles="https://gitlab.gnome.org/pwithnall/libgsystemservice/-/archive/${version}/libgsystemservice-${version}.tar.gz"
checksum=06dc0f8533fdfd6fa6acd96c76e2782a97ebbea9bb55fb7b82356dc065a21dcb

libgsystemservice-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove usr/share
	}
}
