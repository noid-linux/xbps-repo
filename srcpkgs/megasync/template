 -DUSE_FREEIMAGE:BOOL=OFF
 -DUSE_PDFIUM:BOOL=OFF
 -DCMAKE_INSTALL_PREFIX=/
 -Wno-dev
 -DCMAKE_EXE_LINKER_FLAGS=-licui18n"
hostmakedepends="pkg-config"
makedepends="crypto++-devel libsodium-devel sqlite-devel libcurl-devel
 icu-devel libmediainfo-devel libuv-devel readline-devel qt5-devel
