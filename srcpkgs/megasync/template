distfiles="https://github.com/meganz/MEGAsync/archive/refs/tags/v${version}_Linux.tar.gz>${pkgname}-v${version}.tar.gz
 https://github.com/meganz/sdk/archive/refs/tags/v${_sdkver}.tar.gz>sdk-v${_sdkver}.tar.gz"
checksum="fbefefbf8575fdd691f4dcc2e200f64e0eadf45bb79d06e90d665bd97eeedeae
 293af0310a35ce8342a735f11e35a8a4f6da292cfd065f053c6d2fa78956db83"
