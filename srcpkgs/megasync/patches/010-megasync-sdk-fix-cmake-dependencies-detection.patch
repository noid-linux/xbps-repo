From 232bc4fb389a54784a4f5e47c70a45ed30608279 Mon Sep 17 00:00:00 2001
From: Naz <ndpm13@ch-naseem.com>
Date: Thu, 16 Apr 2026 12:14:51 +0100
Subject: [PATCH] fix cmake dependencies detection

---
 src/MEGASync/mega/cmake/modules/configuration.cmake    | 2 +-
 src/MEGASync/mega/cmake/modules/sdklib_libraries.cmake | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/MEGASync/mega/cmake/modules/configuration.cmake b/src/MEGASync/mega/cmake/modules/configuration.cmake
index ef72c04..fdce455 100644
--- a/src/MEGASync/mega/cmake/modules/configuration.cmake
+++ b/src/MEGASync/mega/cmake/modules/configuration.cmake
@@ -38,7 +38,7 @@ else()
     include(CheckSymbolExists)
     check_symbol_exists(glob glob.h HAVE_GLOB_H)
 
-    check_function_exists(aio_write, HAVE_AIO_RT)
+    check_function_exists(aio_write HAVE_AIO_RT)
 
     # Check if our toolchain supports TI emulation mode.
     try_compile(SUPPORTS_TI_EMULATION_MODE
diff --git a/src/MEGASync/mega/cmake/modules/sdklib_libraries.cmake b/src/MEGASync/mega/cmake/modules/sdklib_libraries.cmake
index d50b12e..377f202 100644
--- a/src/MEGASync/mega/cmake/modules/sdklib_libraries.cmake
+++ b/src/MEGASync/mega/cmake/modules/sdklib_libraries.cmake
@@ -98,7 +98,7 @@ macro(load_sdklib_libraries)
 
         find_package(PkgConfig REQUIRED) # For libraries loaded using pkg-config
 
-        pkg_check_modules(cryptopp REQUIRED IMPORTED_TARGET libcrypto++)
+        pkg_check_modules(cryptopp REQUIRED IMPORTED_TARGET libcryptopp)
         target_link_libraries(SDKlib PUBLIC PkgConfig::cryptopp) # TODO: Private for SDK core
 
         pkg_check_modules(sodium REQUIRED IMPORTED_TARGET libsodium)
@@ -143,7 +143,7 @@ macro(load_sdklib_libraries)
         endif()
 
         if(USE_PDFIUM)
-            pkg_check_modules(pdfium REQUIRED IMPORTED_TARGET pdfium)
+            pkg_check_modules(pdfium REQUIRED IMPORTED_TARGET libpdfium)
             target_link_libraries(SDKlib PRIVATE PkgConfig::pdfium)
             set(HAVE_PDFIUM 1)
         endif()
-- 
2.53.0

