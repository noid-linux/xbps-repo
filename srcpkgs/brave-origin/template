# Template file for 'brave-origin'
pkgname=brave-origin
version=1.91.180
revision=1
archs="x86_64"
depends="vulkan-loader"
short_desc="Minimalist browser from the makers of Brave"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="MPL-2.0"
homepage="https://brave.com"
changelog="https://raw.githubusercontent.com/brave/brave-browser/refs/heads/master/CHANGELOG_DESKTOP_ORIGIN.md"
distfiles="https://github.com/brave/brave-browser/releases/download/v${version}/${pkgname}-${version}-linux-amd64.zip"
checksum=931c1a7090d090382d8c5f867f0e97fe9f19b422447cb050b3921150b0a95c67
nostrip=yes
skiprdeps="/opt/${pkgname}/libqt5_shim.so /opt/${pkgname}/libqt6_shim.so"
replaces="brave-browser-origin>=0"
conflicts="brave>=0"

do_install() {
	vmkdir opt/${pkgname}
	vcopy "*" opt/${pkgname}

	rm ${DESTDIR}/opt/${pkgname}/libvulkan.so.1
	rm ${DESTDIR}/opt/${pkgname}/default-app-block

	rm -rf ${DESTDIR}/opt/${pkgname}/cron
	rm -rf ${DESTDIR}/opt/${pkgname}/MEIPreload
	rm -rf ${DESTDIR}/opt/${pkgname}/PrivacySandboxAttestationsPreloaded

	chmod 4755 ${DESTDIR}/opt/${pkgname}/chrome-sandbox

	vbin ${FILESDIR}/${pkgname}.sh brave

	vinstall ${FILESDIR}/brave-origin.desktop 644 usr/share/applications
	vinstall ${FILESDIR}/com.brave.Origin.desktop 644 usr/share/applications
	vlicense LICENSE

	for size in 16 24 32 48 64 128 256; do
		vinstall product_logo_${size}.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps ${pkgname}.png
	done
	rm -f ${DESTDIR}/opt/${pkgname}/product_logo_*.png
}

brave-browser-origin_package() {
	short_desc+=" - (Dummy transitional package)"
	metapackage=yes
	depends="brave-origin-${version}_${revision}"
}
