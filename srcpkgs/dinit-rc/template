# Template file for 'dinit-rc'
pkgname=dinit-rc
version=0.6.4
revision=6
archs="x86_64"
build_style=gnu-makefile
make_dirs="/var/log/dinit 0755 root root"
hostmakedepends="pkg-config scdoc"
makedepends="dbus-devel"
depends="dinit eudev bash"
short_desc="rc scripts and boot services for dinit"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="BSD-2-Clause"
homepage="https://github.com/noid-linux/dinit-rc"
distfiles="https://github.com/noid-linux/dinit-rc/archive/refs/tags/${version}.tar.gz"
checksum=52619aa9defb1bdb5ba2e3a5456bbfb11de292280fff0a4edd55ae166d0a6868
conf_files="
 /etc/dinit.d/config/console.conf
 /etc/hwclock.conf"

post_install() {
	ln -sf dinit ${DESTDIR}/usr/bin/init
	vlicense COPYING
}
