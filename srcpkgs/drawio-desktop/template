# Template file for 'drawio-desktop'
pkgname=drawio-desktop
version=30.2.4
revision=1
_drawiover=115702314f9c4a324f2054898f989d195b01e16b
_electronver=35
archs="x86_64"
hostmakedepends="nodejs electron${_electronver}-devel"
depends="electron${_electronver}"
short_desc="Official electron build of draw.io, a JS editor for general diagramming"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="GPL-3.0-or-later"
homepage="https://www.diagrams.net/"
_baseurl="https://github.com/jgraph/drawio"
distfiles="${_baseurl}-desktop/archive/refs/tags/v${version}.tar.gz>drawio-desktop.tar.gz
 ${_baseurl}/archive/${_drawiover}.tar.gz>drawio.tar.gz"
checksum="eddc10b42d5b9217355bb812c5200a12b09a5aa60a7c66f453a171f1c377d547
 49d19b2a8df6aeace34b367558ed487ec0342622fd9fa7596b6b73287f4c8d04"
skip_extraction="drawio.tar.gz"

post_extract() {
	vsrcextract -C drawio "drawio.tar.gz"
}

pre_build() {
	npm ci
}

do_build() {
	npm run release-linux -- --linux dir \
		-c.electronVersion="$(cat /usr/lib/electron${_electronver}/version)" \
		-c.electronDist="/usr/lib/electron${_electronver}"
}

do_install() {
	vmkdir /usr/lib/drawio-desktop
	vcopy dist/linux-unpacked/resources usr/lib/drawio-desktop/resources

	sed "s/@electronver@/${_electronver}/g" ${FILESDIR}/drawio.sh > ${TMPDIR}/drawio.sh
	vbin ${TMPDIR}/drawio.sh drawio

	vinstall ${FILESDIR}/drawio.desktop 644 usr/share/applications
}
