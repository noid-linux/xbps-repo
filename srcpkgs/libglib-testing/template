# Template file for 'libglib-testing'
pkgname=libglib-testing
version=0.2.0
revision=1
archs="x86_64"
build_style=meson
hostmakedepends="pkg-config cmake gtk-doc"
makedepends="glib-devel"
short_desc="Lib providing test harnesses and mock classes complementing GLib classes"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="LGPL-2.1-or-later"
homepage="https://gitlab.gnome.org/pwithnall/libglib-testing"
changelog="https://gitlab.gnome.org/pwithnall/libglib-testing/-/raw/main/NEWS"
distfiles="https://gitlab.gnome.org/pwithnall/libglib-testing/-/archive/${version}/${pkgname}-${version}.tar.gz"
checksum=f5110420ad3f03156e237357996365a9f2a8b48ac00a9c99a2fd221cc1d16a4c

libglib-testing-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove usr/share
	}
}
