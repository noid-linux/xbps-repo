# Template file for 'brave'
pkgname=brave
version=1.90.122
revision=1
archs="x86_64"
depends="vulkan-loader"
short_desc="Web browser that blocks ads and trackers by default"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="MPL-2.0"
homepage="https://brave.com"
changelog="https://raw.githubusercontent.com/brave/brave-browser/refs/heads/master/CHANGELOG_DESKTOP.md"
distfiles="https://github.com/brave/brave-browser/releases/download/v${version}/brave-browser-${version}-linux-amd64.zip"
checksum=2fe00f79215c79a65968db4bca28ad6c0e52afc8b6194ff0de725404fba3623f
nostrip=yes
skiprdeps="/opt/brave/libqt5_shim.so /opt/brave/libqt6_shim.so"
replaces="brave-browser>=0"
conflicts="brave-origin>=0"

do_install() {
	vmkdir opt/brave
	vcopy "*" opt/brave

	rm ${DESTDIR}/opt/${pkgname}/libvulkan.so.1
	rm ${DESTDIR}/opt/${pkgname}/default-app-block

	rm -rf ${DESTDIR}/opt/${pkgname}/cron
	rm -rf ${DESTDIR}/opt/${pkgname}/MEIPreload
	rm -rf ${DESTDIR}/opt/${pkgname}/PrivacySandboxAttestationsPreloaded

	chmod 4755 ${DESTDIR}/opt/brave/chrome-sandbox

	vbin ${FILESDIR}/brave-browser.sh brave

	vinstall ${FILESDIR}/brave-browser.desktop 644 usr/share/applications
	vlicense LICENSE

	for size in 16 24 32 48 64 128 256; do
		vinstall product_logo_${size}.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps brave-desktop.png
	done
}

brave-browser_package() {
	short_desc+=" - (Dummy transitional package)"
	metapackage=yes
	depends="brave-${version}_${revision}"
}
