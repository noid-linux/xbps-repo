# Template file for 'rustdesk'
pkgname=rustdesk
version=1.4.7
revision=2
archs="x86_64"
depends="xdotool libva libvdpau"
short_desc="Open-source remote desktop application designed for self-hosting"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="AGPL-3.0-only"
homepage="https://rustdesk.com/"
changelog="https://github.com/rustdesk/rustdesk/releases"
distfiles="https://github.com/rustdesk/rustdesk/releases/download/${version}/rustdesk-${version}-x86_64.deb
 https://github.com/rustdesk/rustdesk/raw/refs/heads/master/LICENCE>LICENSE"
checksum="12f61bb5ceb10a708089903357bd1f98dcb618bd0ea56ec568aaf1713a38070a
 8486a10c4393cee1c25392769ddd3b2d6c242d6ec7928e1414efff7dfb2f07ef"
skip_extraction="LICENSE"
conf_files="
 /etc/pam.d/${pkgname}
 /etc/rustdesk/startwm.sh
 /etc/rustdesk/xorg.conf"
nostrip=yes

do_install() {
	# void specific restructuring
	mkdir -p opt/${pkgname}
	mv usr/share/${pkgname}/${pkgname} opt/${pkgname}
	mv usr/share/${pkgname}/lib opt/${pkgname}
	mv usr/share/${pkgname}/data opt/${pkgname}

	# TODO: add runit init script
	rm -rf usr/share/rustdesk/files/systemd

	vcopy "*" /

	vmkdir usr/bin
	ln -sf /opt/${pkgname}/${pkgname} ${DESTDIR}/usr/bin/${pkgname}

	vlicense ${XBPS_SRCDISTDIR}/${pkgname}-${version}/LICENSE
}
