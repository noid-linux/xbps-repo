# Template file for 'thorium-browser-avx2'
pkgname=thorium-browser-avx2
version=138.0.7204.303
revision=2
archs="x86_64"
depends="vulkan-loader"
short_desc="Chromium fork focused on performance and security - AVX2 build"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="BSD-3-Clause"
homepage="https://thorium.rocks/"
changelog="https://github.com/Alex313031/thorium/releases/"
distfiles="https://github.com/Alex313031/thorium/releases/download/M${version}/thorium-browser_${version}_AVX2.zip
	https://raw.githubusercontent.com/Alex313031/thorium/refs/tags/M${version}/LICENSE.md"
checksum="07b980b76735733a1c45b8cba340a2947aa68f9ccdc6f26511135752d4a1ca22
	2f265beba0a969c8d2959c3268c6cc2cb67b967d8aaa0b78691cf5043a7a4689"
skip_extraction="LICENSE.md"
nostrip=yes

do_install() {
	vmkdir opt/${pkgname}
	vcopy "*" opt/${pkgname}

	vmkdir usr/bin
	ln -sf /opt/${pkgname}/thorium ${DESTDIR}/usr/bin/${pkgname}
	ln -sf /opt/${pkgname}/thorium_shell ${DESTDIR}/usr/bin/${pkgname}-shell

	chmod 4755 ${DESTDIR}/opt/${pkgname}/chrome-sandbox

	vinstall ${FILESDIR}/${pkgname}.desktop 644 usr/share/applications
	vinstall ${FILESDIR}/${pkgname}-shell.desktop 644 usr/share/applications

	for size in 16 24 32 48 64 128 256; do
		vinstall product_logo_${size}.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps ${pkgname}.png
	done
	vinstall thorium_shell.png 644 \
		usr/share/icons/hicolor/256x256/apps ${pkgname}-shell.png

	vlicense ${XBPS_SRCDISTDIR}/${pkgname}-${version}/LICENSE.md

	# clean-up
	rm -f ${DESTDIR}/opt/${pkgname}/product_logo_*.png \
		${DESTDIR}/opt/${pkgname}/product_logo_*.xpm \
		${DESTDIR}/opt/${pkgname}/thorium-portable.desktop \
		${DESTDIR}/opt/${pkgname}/thorium-shell.desktop \
		${DESTDIR}/opt/${pkgname}/README.txt \
		${DESTDIR}/opt/${pkgname}/default-app-block \
		${DESTDIR}/opt/${pkgname}/xdg-mime \
		${DESTDIR}/opt/${pkgname}/xdg-settings \
		${DESTDIR}/opt/${pkgname}/THORIUM-PORTABLE \
		${DESTDIR}/opt/${pkgname}/THORIUM-SHELL
	rm -rf ${DESTDIR}/opt/${pkgname}/default_apps
	rm -rf ${DESTDIR}/opt/${pkgname}/ClearKeyCdm/_platform_specific/linux_arm64
}
