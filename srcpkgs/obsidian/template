# Template file for 'obsidian'
pkgname=obsidian
version=1.12.7
revision=2
archs="x86_64"
short_desc="Private and flexible writing app that adapts to the way you think"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="custom:Proprietary"
homepage="https://obsidian.md/"
changelog="https://obsidian.md/changelog/"
distfiles="https://github.com/obsidianmd/obsidian-releases/releases/download/v${version}/obsidian-${version}.tar.gz"
checksum=fcbe08b111d9c1fdb09b9c08952b06e1c829c62163eba2584c4b4ec859be079d
nostrip=yes

do_install() {
	vmkdir opt/${pkgname}
	vcopy "*" opt/${pkgname}

	chmod 4755 ${DESTDIR}/opt/${pkgname}/chrome-sandbox

	vmkdir usr/bin
	ln -sf /opt/${pkgname}/${pkgname} ${DESTDIR}/usr/bin/${pkgname}
	ln -sf /opt/${pkgname}/${pkgname}-cli ${DESTDIR}/usr/bin/${pkgname}-cli

	vinstall ${FILESDIR}/${pkgname}.desktop 644 usr/share/applications

	vinstall resources/icon.png 644 \
		usr/share/icons/hicolor/512x512/apps obsidian.png
}
