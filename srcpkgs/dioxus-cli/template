# Template file for 'dioxus-cli'
pkgname=dioxus-cli
version=0.7.9
revision=1
archs="x86_64"
build_style=cargo
make_install_args="--path packages/cli"
hostmakedepends="pkg-config"
makedepends="libzstd-devel openssl-devel libgit2-1.9-devel"
short_desc="CLI for building fullstack web, desktop, and mobile apps"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="MIT OR Apache-2.0"
homepage="https://dioxuslabs.com"
distfiles="https://github.com/DioxusLabs/dioxus/archive/refs/tags/v${version}.tar.gz"
checksum=f9ac6d611a71efa0c4945acc16c48fe7c97a9e6674262012e694f295db733012

# No clue why is this needed, probably should be removed in future
# releases
pre_build() {
	: ${make_cmd:=cargo auditable}
	: ${make_verbose:=-v}

	${make_cmd} fetch ${XBPS_VERBOSE+${make_verbose}} \
		--target ${RUST_TARGET}
}

post_install() {
	vlicense LICENSE-APACHE
	vlicense LICENSE-MIT
}
