post_extract() {
	mv materia-theme-${_theme_materia_ver}/* ${build_wrksrc}/plugins/theme_materia/materia-theme/
	mv archdroid-icon-theme-${_icons_archdroid_ver}/* ${build_wrksrc}/plugins/icons_archdroid/archdroid-icon-theme/
	mv gnome-colors-icon-theme-${_icons_gnomecolors_ver}/* ${build_wrksrc}/plugins/icons_gnomecolors/gnome-colors-icon-theme/
	mv oomoxify-${_oomoxify_ver}/* ${build_wrksrc}/plugins/export_oomoxify/
	mv arc-theme-${_theme_arc_ver}/* ${build_wrksrc}/plugins/theme_arc/arc-theme/
	mv numix-icon-theme-${_icons_numix_ver}/* ${build_wrksrc}/plugins/icons_numix/numix-icon-theme/
	mv numix-folders-${_numix_folders_ver}/* ${build_wrksrc}/plugins/icons_numix/numix-folders/
	mv papirus-icon-theme-${_icons_papirus_ver}/* ${build_wrksrc}/plugins/icons_papirus/papirus-icon-theme/
	mv suru-plus-${_icons_suruplus_ver}/* ${build_wrksrc}/plugins/icons_suruplus/suru-plus/
	mv suru-plus-aspromauros-${_icons_suruplus_aspromauros_ver}/* ${build_wrksrc}/plugins/icons_suruplus_aspromauros/suru-plus-aspromauros/
	mv oomox-gtk-theme-${_theme_oomox_ver}/* ${build_wrksrc}/plugins/theme_oomox/
	mv themix-plugin-base16-${_base16_ver}/* ${build_wrksrc}/plugins/base16/
}

post_install() {
	python3 -O -m compileall "${DESTDIR}/opt/${pkgname}/${pkgname}_gui" \
		-d "/opt/${pkgname}/${pkgname}_gui"
}
