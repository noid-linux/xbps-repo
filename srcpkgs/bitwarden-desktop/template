do_install() {
	vcopy "*" /

    vmkdir usr/bin
    ln -sf /opt/Bitwarden/bitwarden ${DESTDIR}/usr/bin/bitwarden

    chmod 4755 ${DESTDIR}/opt/Bitwarden/chrome-sandbox

	rm ${DESTDIR}/opt/Bitwarden/libvulkan.so.1
	rm ${DESTDIR}/opt/Bitwarden/resources/app-update.yml
}
