# Template file for 'zen-browser'
pkgname=zen-browser
version=1.19.1b
revision=1
hostmakedepends="tar xz"
short_desc="Performance oriented Firefox-based web browser"
maintainer="Naz <ndpm13@ch-naeseem.com>"
license="MPL-2.0"
homepage="https://zen-browser.app/"
distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-x86_64.tar.xz"
checksum=40a9d137e6a33e4477e9428d62f245d8e8f4610a72cfb624a97070c2e3ddfdab
nostrip=yes

do_install() {
	vcopy zen /usr/lib/

	vmkdir usr/bin
	ln -sf /usr/lib/zen/zen ${DESTDIR}/usr/bin/zen

	vinstall ${FILESDIR}/zen.desktop 644 usr/share/applications
}